rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can read/write their own doc
    // Any authenticated user can also update ONLY the balance field (for payouts)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance'])
      );
    }

    // Events: authenticated users can read, only creator can update
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.createdBy == request.auth.uid;

      // Bets: authenticated users can read all, create own, never modify/delete
      match /bets/{betId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      }
    }
  }
}
